# ─────────────────────────────────────────────────────────────────────────────
# HackNova environment example
# Copy this to `.env.local` and fill in the values you need.
# Public values (NEXT_PUBLIC_*) are inlined into the browser bundle — never
# put secrets there.
# ─────────────────────────────────────────────────────────────────────────────

# --- Site / SEO ---
# The canonical, public URL of your deployment. Used by metadata, sitemap,
# robots.txt, and the OG image generator.
NEXT_PUBLIC_SITE_URL="https://hacknova.spherehive.in"

# Search Console / Bing Webmaster verification (paste only the content value,
# not the full meta tag). Both are optional.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_BING_SITE_VERIFICATION=""

# --- Database (used by /api/register, /api/track, /api/admin/*) ---
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD=""
DB_NAME="hacknova"

# --- Admin ---
# Key used by the /admin dashboard to authenticate against /api/admin/*.
# Move this OUT of source code (currently hardcoded in
# app/api/admin/registrations/route.ts).
ADMIN_KEY="noor"
